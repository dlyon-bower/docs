{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bower Help Centre",
  "colors": {
    "primary": "#1F3A89",
    "light": "#5E7D4F",
    "dark": "#1F3A89"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "getting-started/install-pwa",
              "trust-centre/index"
            ]
          },
          {
            "group": "Capture",
            "pages": [
              "capture/mobile-capture",
              "capture/batch-import",
              "capture/editor",
              "capture/annotations-and-diagrams",
              "capture/version-history",
              "capture/keyboard-shortcuts"
            ]
          },
          {
            "group": "AI & Search",
            "pages": [
              "ai-and-search/bird-ai-assistant",
              "ai-and-search/personal-preferences",
              "ai-and-search/workspace-instructions",
              "ai-and-search/live-agent-mode",
              "ai-and-search/hybrid-search",
              "capture/ai-titles"
            ]
          },
          {
            "group": "Organisation",
            "pages": [
              "organisation/collections",
              "organisation/notes-vs-attachments",
              "organisation/protocols",
              "organisation/tags",
              "organisation/linked-entities",
              "organisation/organising-workspace",
              "organisation/export",
              "organisation/sharing-artifacts"
            ]
          },
          {
            "group": "Workspaces & Account",
            "pages": [
              "workspaces-and-account/create-workspace",
              "workspaces-and-account/invite-team-members",
              "workspaces-and-account/permissions-overview",
              "workspaces-and-account/switch-workspaces",
              "workspaces-and-account/manage-account",
              "workspaces-and-account/billing",
              "workspaces-and-account/dark-mode",
              "workspaces-and-account/feedback"
            ]
          }
        ]
      },
      {
        "tab": "Trust Centre",
        "groups": [
          {
            "group": "Trust Centre",
            "pages": [
              "trust-centre/index",
              "trust-centre/data-privacy",
              "trust-centre/sub-processors",
              "trust-centre/cookies",
              "trust-centre/audit-logs",
              "trust-centre/hipaa-compliance",
              "trust-centre/password-and-security",
              "trust-centre/privacy-policy",
              "trust-centre/terms-of-service"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Bower App",
          "href": "https://app.bowerlabs.ai",
          "icon": "flask"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@bowerlabs.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Bower",
      "href": "https://app.bowerlabs.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt"
    ]
  },
  "redirects": [
    {
      "source": "/ai-and-search/workspace-memory",
      "destination": "/ai-and-search/workspace-instructions"
    },
    {
      "source": "/ai-and-search/workspace-context",
      "destination": "/ai-and-search/workspace-instructions"
    },
    {
      "source": "/ai-and-search/personal-context",
      "destination": "/ai-and-search/personal-preferences"
    }
  ],
  "footer": {}
}
